# Copia a .env.local y rellena con tus valores (no subas .env.local a git).

# Supabase — Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_publica

# Telegram — notificaciones (API route /api/notify-telegram)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SMTP — emails (API route /api/notify-email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Opcional: en desarrollo, forzar destino de prueba en lugar del email del barbero
# EMAIL_TEST_OVERRIDE=tu@email.com
